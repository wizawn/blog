# 节点列表
# 🇸🇬 新加坡 -Gemini: t.cnmjcn.cyou:16618
# 🇮🇳 印度 - 优化：planb.mojcn.com:16626
# 🇹🇼 台湾 - 优化 3: t.cnmjcn.cyou:16616

# ============================================
# HTTP API 服务器配置
# ============================================
API_HOST=0.0.0.0
API_PORT=5000
API_DEBUG=false

# ============================================
# 合约交易配置
# ============================================
FUTURES_ENABLED=true
MAX_LEVERAGE=5

# ============================================
# 风控配置
# ============================================
MAX_ORDER_VALUE=10000
MAX_DAILY_LOSS=1000
MAX_POSITION_SIZE=0.1
ENABLE_STOP_LOSS=true
DEFAULT_STOP_LOSS_PERCENT=0.05

# ============================================
# OpenClaw 集成配置
# ============================================
OPENCLAW_ENABLED=true
OPENCLAW_JSON_OUTPUT=true
OPENCLAW_AUTO_CONFIRM=true
OPENCLAW_NLP_ENABLED=true
OPENCLAW_SKILLS_ENABLED=true
OPENCLAW_HTTP_API_ENABLED=true

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=INFO
LOG_FILE=~/.clawguard/clawguard.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5

# ============================================
# 高级配置
# ============================================
REQUEST_TIMEOUT=30
MAX_RETRIES=3
ENABLE_CACHE=true
CACHE_EXPIRY=60
