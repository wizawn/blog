# ClawGuard-BNB 环境配置模板
# 复制此文件为 .env 并填写您的配置

# ============================================
# 币安 API 配置
# ============================================

# 币安 API 密钥（必需，除非使用测试网）
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# 使用测试网（true/false）
# true: 使用测试网，无需真实 API 密钥
# false: 使用主网，需要真实 API 密钥
USE_TESTNET=true

# ============================================
# 代理配置（可选）
# ============================================

# 代理服务器 URL
# 格式: http://host:port 或 socks5://host:port
# 留空表示不使用代理
PROXY_URL=

# 代理认证（可选）
PROXY_USERNAME=
PROXY_PASSWORD=

# ============================================
# HTTP API 服务器配置
# ============================================

# 监听地址
API_HOST=0.0.0.0

# 监听端口
API_PORT=5000

# 调试模式（true/false）
API_DEBUG=false

# ============================================
# 合约交易配置
# ============================================

# 启用合约交易（true/false）
FUTURES_ENABLED=false

# 最大杠杆倍数（1-125）
MAX_LEVERAGE=5

# ============================================
# 风控配置
# ============================================

# 最大单笔订单价值（USDT）
MAX_ORDER_VALUE=10000

# 最大每日亏损（USDT）
MAX_DAILY_LOSS=1000

# 最大持仓比例（0-1）
MAX_POSITION_SIZE=0.1

# 启用止损（true/false）
ENABLE_STOP_LOSS=true

# 默认止损百分比（0-1）
DEFAULT_STOP_LOSS_PERCENT=0.05

# ============================================
# OpenClaw 集成配置
# ============================================

# 启用 OpenClaw 集成（true/false）
OPENCLAW_ENABLED=true

# 自动 JSON 输出（true/false）
OPENCLAW_JSON_OUTPUT=true

# 自动确认（跳过交互式确认）（true/false）
OPENCLAW_AUTO_CONFIRM=true

# 启用 NLP（true/false）
OPENCLAW_NLP_ENABLED=true

# 启用 Skills（true/false）
OPENCLAW_SKILLS_ENABLED=true

# 启用 HTTP API（true/false）
OPENCLAW_HTTP_API_ENABLED=true

# ============================================
# 日志配置
# ============================================

# 日志级别（DEBUG/INFO/WARNING/ERROR）
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=~/.clawguard/clawguard.log

# 日志文件最大大小（字节）
LOG_MAX_SIZE=10485760

# 日志文件备份数量
LOG_BACKUP_COUNT=5

# ============================================
# 高级配置
# ============================================

# 请求超时（秒）
REQUEST_TIMEOUT=10

# 最大重试次数
MAX_RETRIES=3

# 启用请求缓存（true/false）
ENABLE_CACHE=true

# 缓存过期时间（秒）
CACHE_EXPIRY=60

# ============================================
# 使用说明
# ============================================

# 1. 复制此文件为 .env
#    cp .env.example .env

# 2. 编辑 .env 文件，填写您的配置
#    nano .env

# 3. 运行自动配置脚本
#    python3 openclaw_configure.py

# 4. 启动服务
#    python3 openclaw_server.py

# ============================================
# 安全提示
# ============================================

# ⚠️ 重要：
# - 不要将 .env 文件提交到 Git
# - 不要分享您的 API 密钥
# - 定期更换 API 密钥
# - 使用 IP 白名单限制 API 访问
# - 不要给 API 密钥提现权限

# ============================================
# 快速配置示例
# ============================================

# 示例1: 测试网模式（无需 API 密钥）
# USE_TESTNET=true
# OPENCLAW_ENABLED=true

# 示例2: 主网模式 + 代理
# BINANCE_API_KEY=abc123...
# BINANCE_API_SECRET=xyz789...
# USE_TESTNET=false
# PROXY_URL=http://127.0.0.1:7890

# 示例3: 合约交易模式
# BINANCE_API_KEY=abc123...
# BINANCE_API_SECRET=xyz789...
# USE_TESTNET=false
# FUTURES_ENABLED=true
# MAX_LEVERAGE=3
